  "item": [
    {
      "name": "00 - SETUP (run once on fresh database)",
      "description": "Creates the initial users required by all other requests. Run these in order on a fresh database before executing any other folder.",
      "item": [
        {
          "name": "1. Bootstrap Admin (MEDICO)",
          "description": "Creates the first user with ROLE_MEDICO via the open bootstrap endpoint. Only works when the users table is empty. Requires username, password, nome, email and role.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url_agendamento}}/api/users/bootstrap-admin",
              "host": [
                "{{base_url_agendamento}}"
              ],
              "path": [
                "api",
                "users",
                "bootstrap-admin"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username_medico}}\",\n  \"password\": \"{{password_medico}}\",\n  \"nome\": \"Dr. Medico\",\n  \"email\": \"{{username_medico}}\",\n  \"telefone\": \"(11) 99999-0001\",\n  \"role\": \"ROLE_MEDICO\"\n}"
            }
          }
        },
        {
          "name": "2. Register PACIENTE",
          "description": "Registers a paciente user. /auth/register always assigns ROLE_PACIENTE automatically.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url_agendamento}}/auth/register",
              "host": [
                "{{base_url_agendamento}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username_paciente}}\",\n  \"password\": \"{{password_paciente}}\",\n  \"nome\": \"Paciente Teste\",\n  \"email\": \"{{username_paciente}}\",\n  \"telefone\": \"(11) 99999-0002\"\n}"
            }
          }
        },
        {
          "name": "3. Login as MEDICO (Setup)",
          "description": "Verifies that the MEDICO credentials are correct.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url_agendamento}}/auth/login",
              "host": [
                "{{base_url_agendamento}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username_medico}}\",\n  \"password\": \"{{password_medico}}\"\n}"
            }
          }
        },
        {
          "name": "4. Create ENFERMEIRO (via admin)",
          "description": "Creates the enfermeiro user with ROLE_ENFERMEIRO via POST /api/users, which requires a MEDICO token. /auth/register cannot be used here because it always assigns ROLE_PACIENTE.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url_agendamento}}/api/users",
              "host": [
                "{{base_url_agendamento}}"
              ],
              "path": [
                "api",
                "users"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username_enfermeiro}}\",\n  \"password\": \"{{password_enfermeiro}}\",\n  \"nome\": \"Enfermeiro Teste\",\n  \"email\": \"{{username_enfermeiro}}\",\n  \"telefone\": \"(11) 99999-0003\",\n  \"role\": \"ROLE_ENFERMEIRO\"\n}"
            },
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username_medico}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password_medico}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "5. Create MEDICO Profile",
          "description": "Creates the medico profile in the medicos table. Must run after step 1. On a fresh database the medico user will have userId=1.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
