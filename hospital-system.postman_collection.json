            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"crm\": \"CRM-12345\",\n  \"especialidade\": \"CARDIOLOGIA\",\n  \"descricao\": \"Médico cardiologista\"\n}"
            },
            "auth": {
              "type": "basic",
